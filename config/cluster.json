    },

    "hbm": {
        "capacity_gb": 64,
        "bandwidth_gbps": 1200,
        "description": "HBM2e per NPU"
    },

    "ub": {
        "capacity_kb": 192,
        "description": "Unified Buffer (on-chip scratchpad) per NPU core"
    },

    "available_algorithms": [
        "Ring AllReduce",
